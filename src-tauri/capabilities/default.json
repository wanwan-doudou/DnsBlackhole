{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "主窗口所需权限",
  "windows": ["main"],
  "permissions": [
    "core:app:allow-version",
    "core:event:allow-listen",
    "updater:allow-check",
    "updater:allow-download-and-install",
    "process:allow-restart",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        {
          "url": "https://github.com/wanwan-doudou/DnsBlackhole"
        },
        {
          "url": "https://github.com/wanwan-doudou/DnsBlackhole/releases*"
        },
        {
          "url": "https://github.com/wanwan-doudou/DnsBlackhole/issues*"
        },
        {
          "url": "https://github.com/wanwan-doudou/DnsBlackhole/blob/main/LICENSE"
        }
      ]
    },
    "dialog:default"
  ]
}
